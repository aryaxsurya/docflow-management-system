        body { font-family: 'Inter', sans-serif; background: #080f1f; color: #e6eeff; }
        .glass { background: rgba(255,255,255,0.08); backdrop-filter: blur(14px); border: 1px solid rgba(255,255,255,0.12); }
        .tab-active { background: rgba(255,255,255,0.16); border-color: #818cf8; }
    </style>
</head>

<body class="min-h-screen flex">

    <!-- SIDEBAR -->
    <aside class="w-64 glass min-h-screen p-6">
